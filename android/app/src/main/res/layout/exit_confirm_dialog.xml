<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="300dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/exit_dialog_bg"
    android:padding="28dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🛑 플로팅 종료"
        android:textColor="#e8c96a"
        android:textSize="18sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:gravity="center"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="플로팅 버튼을 종료할까요?"
        android:textColor="#f0ead8"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_marginBottom="24dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2">

        <Button
            android:id="@+id/btn_exit_cancel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="취소"
            android:textColor="#8a7a5a"
            android:textSize="13sp"
            android:background="@drawable/exit_btn_cancel_bg"
            android:layout_marginEnd="6dp"
            android:textAllCaps="false"/>

        <Button
            android:id="@+id/btn_exit_confirm"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="종료"
            android:textColor="#080808"
            android:textSize="13sp"
            android:textStyle="bold"
            android:background="@drawable/exit_btn_confirm_bg"
            android:layout_marginStart="6dp"
            android:textAllCaps="false"/>
    </LinearLayout>
</LinearLayout>