<?xml version="1.0" encoding="utf-8"?>
<!--
  수정 내용:
  - 기존: 72dp 원형 버튼 하나
  - 변경: 가로 LinearLayout으로 감싸서 ☰ 버튼(panel_toggle_btn) + 메인 카운터 버튼을 하나의 View로 통합
  - 이유: 별도 WindowManager View로 분리되어 있으면 이동 시 위치가 어긋나는 버그 발생
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:elevation="8dp">

    <!-- ☰ 패널 토글 버튼 (왼쪽) -->
    <TextView
        android:id="@+id/panel_toggle_btn"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:gravity="center"
        android:text="☰"
        android:textSize="15sp"
        android:textColor="#C9A84C"
        android:background="#DD141414"/>

    <!-- 메인 카운터 버튼 (오른쪽) -->
    <LinearLayout
        android:id="@+id/main_counter_btn"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/floating_bg">

        <TextView
            android:id="@+id/float_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#080808"
            android:textSize="9sp"
            android:textStyle="bold"
            android:maxLines="1"/>

        <TextView
            android:id="@+id/float_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#080808"
            android:textSize="24sp"
            android:textStyle="bold"/>

    </LinearLayout>

</LinearLayout>
